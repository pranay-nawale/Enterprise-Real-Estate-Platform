# .gitignore
# Node.js dependencies
node_modules/
client/node_modules/
server/node_modules/

# Build output
client/build/
client/dist/
server/dist/

# Logs
npm-debug.log*
yarn-debug.log*
*.log
logs/

# Environment files
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# IDE/editor folders
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Test coverage
coverage/

# Miscellaneous
.tmp/
